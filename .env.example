# --- LLM Providers ---
GROQ_API_KEY=gsk_your_key_here
GROQ_FALLBACK=ollama              # ollama | none
LLM_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL_FAST=llama3.2:3b
OLLAMA_MODEL_QUALITY=llama3.1:8b

# --- Search APIs ---
BRAVE_API_KEY=BSA_your_key_here
# Optional — higher Semantic Scholar rate limits
SEMANTIC_SCHOLAR_API_KEY=
# Optional — OpenAlex polite pool (any contact email)
OPENALEX_MAILTO=you@example.com
# Optional — NCBI / PubMed (improves rate limits)
NCBI_API_KEY=
NCBI_EMAIL=you@example.com

# --- Observability (optional) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Storage paths ---
SQLITE_PATH=data/research.db
FAISS_INDEX_PATH=data/faiss_index/
GRAPH_PATH=data/graphs/

# --- Embeddings ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Cache ---
CACHE_TTL_SECONDS=1800
